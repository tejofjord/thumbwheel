{
  "name": "thumbwheel",
  "version": "0.0.1",
  "description": "Thumb-anchored radial wheel UI for one-handed mobile navigation. SVG sectors, momentum spin, dock-snapping trigger.",
  "keywords": [
    "react",
    "mobile",
    "navigation",
    "radial-menu",
    "pie-menu",
    "wheel",
    "thumbwheel",
    "svg",
    "ios"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tejofjord/thumbwheel.git"
  },
  "homepage": "https://github.com/tejofjord/thumbwheel#readme",
  "bugs": {
    "url": "https://github.com/tejofjord/thumbwheel/issues"
  }
}
